rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// RECESS — Firestore security rules
//
// Model: each user belongs to one school (schoolId). Roles: parent, teacher,
// student, admin, organizer. Parents see only their own children; staff
// (teacher/admin) see data within their own school; everyone manages only
// their own user doc and notifications.
//
// Deploy:  firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    // Current user's profile document.
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return hasProfile() ? profile().role : '';
    }
    function mySchool() {
      return hasProfile() ? profile().schoolId : '';
    }
    function isAdmin() {
      return role() == 'admin' || role() == 'organizer';
    }
    function isStaff() {
      return role() == 'teacher' || isAdmin();
    }
    function studentParents(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data.parentIds;
    }
    function threadParticipants(threadId) {
      return get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Read your own profile; staff can read profiles within their school.
    // A new user creates their own doc during registration (uid == auth.uid).
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        (isStaff() && resource.data.schoolId == mySchool())
      );
      allow list:   if isStaff();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Schools ──────────────────────────────────────────────────────────────
    // NOTE: read is public because registration resolves the school by access
    // code BEFORE the auth account exists (see lib/auth.ts). For stronger
    // privacy, move access-code validation into a server route / Cloud Function
    // using the Admin SDK, then tighten this to `allow read: if isSignedIn()`.
    match /schools/{schoolId} {
      allow read:  if true;
      allow write: if isAdmin() && mySchool() == schoolId;
    }

    // ── Students ─────────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.parentIds ||
        (isStaff() && resource.data.schoolId == mySchool())
      );
      allow create: if isStaff() && request.resource.data.schoolId == mySchool();
      allow update, delete: if isStaff() && resource.data.schoolId == mySchool();
    }

    // ── Student progress ─────────────────────────────────────────────────────
    // Doc IDs look like  {studentId}_{schoolYear}_T{term}  but access is gated
    // on the studentId field, not the doc name.
    match /studentProgress/{progressId} {
      allow read: if isSignedIn() && (
        isStaff() ||
        request.auth.uid in studentParents(resource.data.studentId)
      );
      allow write: if isStaff();
    }

    // ── Assignments ──────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }

    // ── Assignment submissions ───────────────────────────────────────────────
    match /assignmentSubmissions/{submissionId} {
      allow read: if isSignedIn() && (
        isStaff() ||
        request.auth.uid in studentParents(resource.data.studentId)
      );
      allow write: if isStaff();
    }

    // ── Messaging ────────────────────────────────────────────────────────────
    match /messageThreads/{threadId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn()
        && request.auth.uid in threadParticipants(resource.data.threadId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.auth.uid in threadParticipants(request.resource.data.threadId);
      allow update, delete: if isSignedIn()
        && request.auth.uid == resource.data.senderId;
    }

    // ── Workshops (public marketing catalogue) ───────────────────────────────
    match /workshops/{workshopId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Workshop bookings are made by school staff.
    match /workshopBookings/{bookingId} {
      allow read, write: if isStaff();
    }

    // ── Calendar & announcements (school-scoped) ─────────────────────────────
    match /calendarEvents/{eventId} {
      allow read:  if isSignedIn() && resource.data.schoolId == mySchool();
      allow create: if isStaff() && request.resource.data.schoolId == mySchool();
      allow update, delete: if isStaff() && resource.data.schoolId == mySchool();
    }

    match /announcements/{announcementId} {
      allow read:  if isSignedIn() && resource.data.schoolId == mySchool();
      allow create: if isStaff() && request.resource.data.schoolId == mySchool();
      allow update, delete: if isStaff() && resource.data.schoolId == mySchool();
    }

    // ── Notifications (private to each user) ─────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
    }

    // ── Default: deny everything not explicitly allowed above ────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
